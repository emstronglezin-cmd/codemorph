# ============================================================
# CodeMorph — Frontend Environment Variables
# Copy to .env.local for local development
# ============================================================

# ── API ──────────────────────────────────────────────────────
# Backend NestJS API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── App ──────────────────────────────────────────────────────
# Public app URL (used for PWA manifest metadataBase + OG images)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ───────────────────────────────────────────────────
# Publishable key (safe to expose — starts with pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Feature flags ────────────────────────────────────────────
# Set to "true" to enable billing UI (Stripe checkout, plan upgrade)
NEXT_PUBLIC_FEATURE_BILLING=false
# Set to "true" to enable analytics tracking
NEXT_PUBLIC_FEATURE_ANALYTICS=false
