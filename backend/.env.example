# ============================================================
# CodeMorph Backend — Variables d'environnement
# Copier ce fichier → backend/.env pour le développement local
# NE JAMAIS commiter un fichier .env avec de vraies valeurs
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ── Database PostgreSQL (Supabase — gratuit permanent) ───────
# Développement local (avec docker-compose.yml)
DATABASE_URL=postgresql://codemorph:codemorph@localhost:5432/codemorph
DATABASE_SSL=false

# Production Supabase (Transaction pooler, port 6543)
# Récupérer depuis : supabase.com → Project Settings → Database → Connection string → Transaction pooler
# DATABASE_URL=postgresql://postgres.XXXXXXXXXX:YOUR-PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true
#
# ⚠️ Pour les migrations, utiliser la Direct Connection (port 5432) :
# DATABASE_URL=postgresql://postgres.XXXXXXXXXX:YOUR-PASSWORD@db.XXXXXXXXXX.supabase.co:5432/postgres
#
# Guide complet : docs/SUPABASE_SETUP.md

# ── Redis (pour Bull queues) ──────────────────────────────────
# Développement local
REDIS_URL=redis://localhost:6379
# Production Upstash (gratuit 10k req/jour)
# REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ── JWT ───────────────────────────────────────────────────────
# Générer : openssl rand -base64 64
JWT_SECRET=change-me-in-production-64-bytes-random-string
JWT_REFRESH_SECRET=change-me-in-production-another-64-bytes-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Session / Cookies ─────────────────────────────────────────
# Générer : openssl rand -base64 32
COOKIE_SECRET=change-me-32-bytes-random

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production : https://your-project.vercel.app

# ── GitHub OAuth ──────────────────────────────────────────────
# Créer : github.com/settings/developers → OAuth Apps → New OAuth App
GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback
# Production : https://codemorph-backend.onrender.com/api/v1/auth/github/callback

# ── Google OAuth ──────────────────────────────────────────────
# Créer : console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
# Production : https://codemorph-backend.onrender.com/api/v1/auth/google/callback

# ── AI Engine ─────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:5000
AI_ENGINE_SECRET=ai-engine-secret-change-in-production

# ── LeekPay (système de paiement XOF/EUR/USD) ─────────────────
# Clés disponibles sur dashboard.leekpay.fr → Clés API
LEEKPAY_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE
LEEKPAY_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE
# URL du backend pour webhook par défaut
BACKEND_URL=https://codemorph-hp00.onrender.com
# Webhook configuré dans LeekPay Dashboard :
# https://codemorph-hp00.onrender.com/api/v1/payments/webhook

# ── Feature flags ─────────────────────────────────────────────
FEATURE_BILLING=false
FEATURE_ANALYTICS=false
