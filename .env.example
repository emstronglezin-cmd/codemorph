# ============================================================
# CodeMorph — Environment Variables Example
# Copy to .env.local for development, .env for production
# NEVER commit .env files to version control
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=codemorph-backend
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://codemorph:secret@localhost:5432/codemorph_dev
DATABASE_SSL=false
# DATABASE_SSL=true  # enable in production

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE_DB=1

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-very-long-random-secret-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-very-long-random-secret-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Engine ────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:5000
OPENAI_API_KEY=sk-...

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── GitHub OAuth ─────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# ── Stripe Billing ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MAX_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_MAX_YEARLY_PRICE_ID=price_...

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info

# ── Uploads ──────────────────────────────────────────────────
UPLOAD_DIR=/tmp/codemorph-uploads
MAX_UPLOAD_SIZE_MB=100

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Docker / Production overrides ───────────────────────────
# POSTGRES_USER=codemorph
# POSTGRES_PASSWORD=strong-password-here
# POSTGRES_DB=codemorph_prod
# REDIS_PASSWORD=strong-redis-password
