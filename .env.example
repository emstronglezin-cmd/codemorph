# ============================================================
# CodeMorph — Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── APP ──────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=CodeMorph
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_ENGINE_URL=http://localhost:5000

# ── FRONTEND (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CodeMorph
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── BACKEND (NestJS) ─────────────────────────────────────────
PORT=4000
API_PREFIX=api/v1

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://codemorph:password@localhost:5432/codemorph_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=codemorph
DATABASE_PASSWORD=password
DATABASE_NAME=codemorph_db
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AI ENGINE ────────────────────────────────────────────────
AI_PORT=5000
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AI_MODEL_DEFAULT=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2

# ── AUTH / OAUTH ─────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── EMAIL ────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=your-resend-api-key
EMAIL_FROM=noreply@codemorph.dev

# ── STORAGE (S3 / R2) ────────────────────────────────────────
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=codemorph-uploads

# ── STRIPE ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ── MONITORING ───────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=debug

# ── FEATURE FLAGS ────────────────────────────────────────────
FEATURE_AI_ENGINE=true
FEATURE_BILLING=true
FEATURE_TEAMS=true
FEATURE_ANALYTICS=true
