# ============================================================
# CodeMorph — Variables d'environnement complètes
# Copier ce fichier → backend/.env et ai-engine/.env pour le développement local
# NE JAMAIS commiter les fichiers .env avec de vraies valeurs
# ============================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BACKEND (backend/.env)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ── Database PostgreSQL (Supabase — gratuit permanent) ───────────
# Développement local (avec docker-compose.yml)
DATABASE_URL=postgresql://codemorph:codemorph@localhost:5432/codemorph
DATABASE_SSL=false

# Production Supabase (Transaction pooler, port 6543)
# Récupérer depuis : Project Settings → Database → Connection string → Transaction pooler
# DATABASE_URL=postgresql://postgres.XXXXXXXXXX:YOUR-PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true
#
# Guide complet : docs/SUPABASE_SETUP.md

# ── Redis (pour Bull queues) ──────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production Render: injecté automatiquement

# ── JWT ───────────────────────────────────────────────────────
# Générer: openssl rand -base64 64
# CRITIQUE : Ces deux variables DOIVENT être définies en production (rejet au démarrage sinon)
# Générer: openssl rand -base64 64
JWT_SECRET=change-me-in-production-64-bytes-random-string
JWT_REFRESH_SECRET=change-me-in-production-another-64-bytes-random-string
# IMPORTANT : Mettre 7d (pas 15m) si le cookie cross-domain Vercel→Render ne fonctionne pas
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Session / Cookies ─────────────────────────────────────────
# Générer: openssl rand -base64 32
COOKIE_SECRET=change-me-32-bytes-random

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: https://your-project.vercel.app

# ── GitHub OAuth ──────────────────────────────────────────────
# Créer: github.com/settings/developers → OAuth Apps → New OAuth App
GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback
# Production: https://codemorph-backend.onrender.com/api/v1/auth/github/callback

# ── Google OAuth ──────────────────────────────────────────────
# Créer: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
# Production: https://codemorph-backend.onrender.com/api/v1/auth/google/callback

# ── AI Engine ─────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:5000
# Secret partagé backend↔ai-engine — générer: openssl rand -base64 32
AI_ENGINE_SECRET=ai-engine-secret-change-in-production

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Feature flags ─────────────────────────────────────────────
FEATURE_BILLING=false
FEATURE_ANALYTICS=false


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI ENGINE (ai-engine/.env)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

AI_PORT=5000
NODE_ENV=development
LOG_LEVEL=debug
AI_ENGINE_SECRET=ai-engine-secret-change-in-production  # Doit être identique à la valeur backend

# ── Backend URL (pour les callbacks) ─────────────────────────
API_URL=http://localhost:4000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STRATÉGIE IA HYBRIDE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── MODE GRATUIT — Groq (Llama 3.1 8B) ───────────────────────
# Gratuit jusqu'à 14 400 req/jour, latence <1s
# Créer un compte: console.groq.com → API Keys
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXX
# Modèle recommandé: llama-3.1-8b-instant (rapide) ou llama-3.3-70b-versatile (meilleur)
AI_MODEL_FREE=llama-3.1-8b-instant

# ── MODE PLATFORM — OpenAI (clé CodeMorph) ───────────────────
# Utilisé si OPENAI_API_KEY est défini (coût pour CodeMorph)
# Laisser vide si budget limité — Groq suffit pour le mode Free
OPENAI_API_KEY=
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── MODE PLATFORM — Anthropic (clé CodeMorph) ────────────────
# Laisser vide — les users Pro fournissent leur propre clé
ANTHROPIC_API_KEY=

# ── Paramètres IA ────────────────────────────────────────────
AI_MODEL_DEFAULT=gpt-4o-mini
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FRONTEND (frontend/.env.local)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Production Vercel: NEXT_PUBLIC_API_URL=https://codemorph-backend.onrender.com/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production Vercel: NEXT_PUBLIC_APP_URL=https://codemorph-coral.vercel.app
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FEATURE_BILLING=false
NEXT_PUBLIC_FEATURE_ANALYTICS=false
