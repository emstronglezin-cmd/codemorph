# ============================================================
# CodeMorph — Complete Environment Variables
# Copy: cp .env.example backend/.env
# NEVER commit .env files to version control
# ============================================================

# ╔══════════════════════════════════════════════════════════╗
# ║                    APP CONFIGURATION                      ║
# ╚══════════════════════════════════════════════════════════╝
NODE_ENV=development
SERVICE_NAME=codemorph-backend
PORT=4000
API_PREFIX=api/v1

# ── URLs ──────────────────────────────────────────────────────
# Backend URL (this service)
API_URL=http://localhost:4000

# Frontend URL — REQUIRED for CORS and OAuth redirects
# Dev:  http://localhost:3000
# Prod: https://your-app.netlify.app
FRONTEND_URL=http://localhost:3000

# Legacy alias (also accepted by CORS)
APP_URL=http://localhost:3000

# AI Engine URL (Python FastAPI service)
AI_ENGINE_URL=http://localhost:5000

# ╔══════════════════════════════════════════════════════════╗
# ║                  DATABASE (PostgreSQL)                    ║
# ╚══════════════════════════════════════════════════════════╝
# Full connection string (overrides individual vars below if set)
DATABASE_URL=postgresql://codemorph:secret@localhost:5432/codemorph_dev

# Individual connection params (fallback if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=codemorph
DB_PASSWORD=secret
DB_NAME=codemorph_dev
DB_SCHEMA=public

# SSL (required on Render / Supabase / Neon)
DATABASE_SSL=false
# DATABASE_SSL=true  # uncomment for production

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ╔══════════════════════════════════════════════════════════╗
# ║                    REDIS (Bull Queues)                    ║
# ╚══════════════════════════════════════════════════════════╝
# Full connection string (preferred — overrides individual vars)
REDIS_URL=redis://localhost:6379

# Individual params (fallback)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE_DB=1
REDIS_TLS=false

# ╔══════════════════════════════════════════════════════════╗
# ║                    JWT / AUTH                             ║
# ╚══════════════════════════════════════════════════════════╝
# CRITICAL: Use long random strings (min 64 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_VERY_LONG_RANDOM_SECRET_MINIMUM_64_CHARACTERS_REQUIRED
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_VERY_LONG_RANDOM_SECRET_64_CHARS_REQUIRED
JWT_REFRESH_EXPIRES_IN=7d

# Cookie signing secret
COOKIE_SECRET=CHANGE_ME_TO_A_RANDOM_COOKIE_SECRET_32_CHARS_MIN

# ╔══════════════════════════════════════════════════════════╗
# ║                  GOOGLE OAUTH 2.0                         ║
# ╚══════════════════════════════════════════════════════════╝
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Callback URL must match exactly what's registered in Google Console
# Dev:  http://localhost:4000/api/v1/auth/google/callback
# Prod: https://your-backend.onrender.com/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ╔══════════════════════════════════════════════════════════╗
# ║                  GITHUB OAUTH                             ║
# ╚══════════════════════════════════════════════════════════╝
# Setup: https://github.com/settings/developers → OAuth Apps → New OAuth App
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Callback URL must match exactly what's registered in GitHub
# Dev:  http://localhost:4000/api/v1/auth/github/callback
# Prod: https://your-backend.onrender.com/api/v1/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# ╔══════════════════════════════════════════════════════════╗
# ║                  STRIPE BILLING                           ║
# ╚══════════════════════════════════════════════════════════╝
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Webhook secret (from: stripe listen --forward-to localhost:4000/api/v1/billing/webhook)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Price IDs (from Stripe dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id
STRIPE_PRICE_PRO_MAX_MONTHLY=price_pro_max_monthly_id
STRIPE_PRICE_PRO_MAX_YEARLY=price_pro_max_yearly_id

# ╔══════════════════════════════════════════════════════════╗
# ║                  EMAIL (SMTP)                             ║
# ╚══════════════════════════════════════════════════════════╝
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your-resend-api-key
SMTP_FROM=noreply@codemorph.dev
SMTP_FROM_NAME=CodeMorph

# ╔══════════════════════════════════════════════════════════╗
# ║                  FEATURE FLAGS                            ║
# ╚══════════════════════════════════════════════════════════╝
FEATURE_AI_ENGINE=true
FEATURE_BILLING=false
FEATURE_TEAMS=false
FEATURE_ANALYTICS=false

# ╔══════════════════════════════════════════════════════════╗
# ║                  OBSERVABILITY                            ║
# ╚══════════════════════════════════════════════════════════╝
LOG_LEVEL=debug
# Sentry DSN (optional)
SENTRY_DSN=

# ╔══════════════════════════════════════════════════════════╗
# ║             FRONTEND ENVIRONMENT VARIABLES               ║
# ╚══════════════════════════════════════════════════════════╝
# These go in frontend/.env.local (prefix NEXT_PUBLIC_)
#
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
