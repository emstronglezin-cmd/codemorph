{
  "name": "@codemorph/ai-engine",
  "version": "1.0.0",
  "private": true,
  "description": "CodeMorph AI Engine — IR Parser, Code Generator, Transformer",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codemorph/shared": "*",
    "axios": "^1.6.8",
    "express": "^4.18.3",
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.20.1",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.28",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
